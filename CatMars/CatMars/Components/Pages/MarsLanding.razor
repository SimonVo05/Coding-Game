@page "/mars-landing"
@rendermode InteractiveServer

<div class="game-container" tabindex="0">
    <img src="images/mars-bg.png" class="background" />
    <img src="images/ship.png" class="spaceship @shipClass" />
    <div class="win-text">You Win!</div>
</div>

@code {
    private string shipClass = "";
    private string winClass = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            shipClass = "landing";
            StateHasChanged();
        }
    }
}
